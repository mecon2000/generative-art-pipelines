---
import BaseLayout from '../layouts/BaseLayout.astro';
import SketchCanvas from '../components/SketchCanvas.astro';
import ThemeCard from '../components/ThemeCard.astro';
import { galleries } from '../data/galleries';

const pieceCounts: Record<string, number> = {
  organic: 3,
  geometric: 3,
  cosmic: 3,
  glitch: 2,
  dimensional: 3,
  photography: 4,
};
---
<BaseLayout title="Generative Art Pipelines">
  <!-- Hero -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden -mt-16">
    <div class="absolute inset-0">
      <SketchCanvas pipelineId="flow-field" theme="organic" interactive={false} class="w-full h-full" />
    </div>
    <div class="absolute inset-0 bg-void/40"></div>
    <div class="relative z-10 text-center px-6 stagger-in">
      <h1 class="font-display italic text-text" style="font-size: clamp(3rem, 8vw, 7rem); line-height: 1;">
        Generative Art<br />Pipelines
      </h1>
      <p class="font-mono text-text-muted mt-6 tracking-widest text-sm">
        Algorithmic beauty. Live in your browser.
      </p>
      <a href="/gallery" class="btn mt-10 inline-flex">
        Explore Galleries
      </a>
    </div>
  </section>

  <!-- Theme Cards -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <h2 class="font-display italic text-4xl text-text mb-12 text-center">Six Worlds</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 stagger-in">
      {galleries.sort((a, b) => a.order - b.order).map(theme => (
        <ThemeCard theme={theme} pieceCount={pieceCounts[theme.id] || 0} />
      ))}
    </div>
  </section>

  <!-- About Strip -->
  <section class="border-t border-border py-20 px-6">
    <div class="max-w-3xl mx-auto text-center space-y-6">
      <p class="text-text-muted leading-relaxed">
        Each piece is generated by a self-contained pipeline — a p5.js sketch with a defined
        parameter schema. Visitors can watch sketches run live, tweak parameters in real time,
        save outputs, and share specific configurations via URL.
      </p>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="border-t border-border py-16 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-3 gap-8 text-center stagger-in">
      <div>
        <p class="font-display italic text-5xl text-accent">18</p>
        <p class="label mt-2">pipelines</p>
      </div>
      <div>
        <p class="font-display italic text-5xl text-accent">6</p>
        <p class="label mt-2">themes</p>
      </div>
      <div>
        <p class="font-display italic text-5xl text-accent">&infin;</p>
        <p class="label mt-2">variations</p>
      </div>
    </div>
  </section>
</BaseLayout>
