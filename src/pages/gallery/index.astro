---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeCard from '../../components/ThemeCard.astro';
import { galleries } from '../../data/galleries';

const pieceCounts: Record<string, number> = {
  organic: 3,
  geometric: 3,
  cosmic: 3,
  glitch: 2,
  dimensional: 3,
  photography: 4,
};
---
<BaseLayout title="Galleries — Generative Art Pipelines">
  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="mb-12 stagger-in">
      <h1 class="font-display italic text-5xl text-text">Galleries</h1>
      <p class="text-text-muted mt-4">Six themed collections. Each a different lens on algorithmic art.</p>
    </div>

    <div class="space-y-8 stagger-in">
      {galleries.sort((a, b) => a.order - b.order).map(theme => (
        <ThemeCard theme={theme} pieceCount={pieceCounts[theme.id] || 0} />
      ))}
    </div>
  </section>
</BaseLayout>
