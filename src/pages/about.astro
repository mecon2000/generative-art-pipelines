---
import BaseLayout from '../layouts/BaseLayout.astro';
import { galleries } from '../data/galleries';
---
<BaseLayout title="About — Generative Art Pipelines">
  <article class="max-w-[65ch] mx-auto px-6 py-20 stagger-in">

    <!-- 1. Hero -->
    <section class="mb-16">
      <h1 class="font-display italic text-text" style="font-size: clamp(3rem, 6vw, 5rem);">
        Who's behind this?
      </h1>
      <p class="text-text-muted mt-4 leading-relaxed">
        A photographer who writes code. A programmer who makes images.
      </p>
    </section>

    <!-- 2. About Me -->
    <section class="mb-16">
      <h2 class="font-display italic text-3xl text-text mb-6">About Me</h2>
      <div class="space-y-4 text-text-muted leading-relaxed">
        <p>
          I'm Ron P Wilder — a photographer and backend developer based in Israel.
          By day I build systems and infrastructure. By night (and weekends, and
          honestly a lot of the in-between) I photograph people.
        </p>
        <p>
          My photography focuses on artistic, carefully composed work — often nude,
          lingerie, and Shibari. I previously co-owned a studio, and my approach
          has always been about deliberate staging, clean composition, and creating
          images where the subject feels genuinely proud of the result. Consent and
          discretion aren't afterthoughts; they're the foundation.
        </p>
        <p>
          This project sits at the intersection of those two worlds. I wanted a
          space where code could transform, distort, and reimagine photographs —
          where algorithms meet images and something unexpected emerges. Some
          galleries here are pure generative art. Others will take my photographs
          and run them through programmatic processes: pixel sorting, noise
          displacement, reaction-diffusion overlays, glitch effects.
        </p>
      </div>
    </section>

    <!-- 3. The Idea -->
    <section class="mb-16">
      <h2 class="font-display italic text-3xl text-text mb-6">The Idea</h2>
      <div class="space-y-4 text-text-muted leading-relaxed">
        <p>
          Generative art sits at the intersection of code and aesthetics — algorithms
          that produce visual beauty not through pixel-perfect design, but through
          emergent behavior. A few lines of math can produce infinite visual variation.
        </p>
        <p>
          Each piece here is a self-contained pipeline: a p5.js sketch with a typed
          parameter schema. You can watch it run live, tweak parameters in real time,
          save the output, and share a specific configuration via URL. Every variation
          is unique.
        </p>
      </div>
    </section>

    <!-- 4. The Themes -->
    <section class="mb-16">
      <h2 class="font-display italic text-3xl text-text mb-6">The Themes</h2>
      <div class="space-y-6">
        {galleries.sort((a, b) => a.order - b.order).map(theme => (
          <div class="flex items-start gap-4">
            <div
              class="w-4 h-4 rounded-full mt-1 flex-shrink-0"
              style={`background: ${theme.accentColor}`}
            ></div>
            <div>
              <h3 class="font-display italic text-xl text-text">{theme.name}</h3>
              <p class="text-text-muted text-sm mt-1">{theme.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 5. Tech Stack -->
    <section class="mb-16">
      <h2 class="font-display italic text-3xl text-text mb-6">Tech Stack</h2>
      <div class="bg-surface border border-border rounded overflow-hidden">
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-border">
              <td class="px-4 py-3 label">Framework</td>
              <td class="px-4 py-3 text-text">Astro</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-4 py-3 label">Art Runtime</td>
              <td class="px-4 py-3 text-text">p5.js</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-4 py-3 label">Styling</td>
              <td class="px-4 py-3 text-text">Tailwind CSS</td>
            </tr>
            <tr>
              <td class="px-4 py-3 label">Deployment</td>
              <td class="px-4 py-3 text-text">Vercel</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 6. Links -->
    <section class="text-center space-y-4">
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="https://www.ronpwilder.com" target="_blank" rel="noopener noreferrer" class="btn inline-flex">
          Photography
        </a>
        <a href="https://github.com/mecon2000" target="_blank" rel="noopener noreferrer" class="btn inline-flex">
          GitHub
        </a>
      </div>
    </section>

  </article>
</BaseLayout>
