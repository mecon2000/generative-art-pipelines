---
import type { ParamValues } from '../pipelines/_types';

interface Props {
  pipelineId: string;
  theme: string;
  params?: ParamValues;
  interactive?: boolean;
  class?: string;
}

const { pipelineId, theme, params, interactive = true, class: className = '' } = Astro.props;
---
<div
  class:list={['sketch-canvas-wrapper relative w-full h-full overflow-hidden', className]}
  data-pipeline-id={pipelineId}
  data-pipeline-theme={theme}
  data-initial-params={params ? JSON.stringify(params) : undefined}
  data-interactive={interactive.toString()}
>
  <div class="sketch-canvas-mount w-full h-full"></div>
  <div class="sketch-error hidden absolute inset-0 flex items-center justify-center bg-surface text-text-muted font-mono text-sm p-4 text-center">
    <span>Failed to load sketch</span>
  </div>
</div>

<script>
  import type { Pipeline, ParamValues } from '../pipelines/_types';

  class SketchRunner {
    private wrapper: HTMLElement;
    private mount: HTMLElement;
    private p5Instance: any = null;
    private pipeline: Pipeline | null = null;
    private state: unknown = null;
    private frame = 0;
    private params: ParamValues = {};
    private destroyed = false;

    constructor(wrapper: HTMLElement) {
      this.wrapper = wrapper;
      this.mount = wrapper.querySelector('.sketch-canvas-mount')!;
      this.init();
    }

    private async init() {
      const id = this.wrapper.dataset.pipelineId!;
      const theme = this.wrapper.dataset.pipelineTheme!;
      const initialParams = this.wrapper.dataset.initialParams;

      try {
        const mod = await import(`../pipelines/${theme}/${id}.ts`);
        const pipeline: Pipeline = Object.values(mod)[0] as Pipeline;
        this.pipeline = pipeline;

        this.params = { ...this.getDefaults() };
        if (initialParams) {
          Object.assign(this.params, JSON.parse(initialParams));
        }

        const p5Module = await import('p5');
        const P5 = p5Module.default;

        this.p5Instance = new P5((p: any) => {
          p.setup = () => {
            const renderer = pipeline.renderer === 'WEBGL' ? (p as any).WEBGL : undefined;
            const canvas = renderer
              ? p.createCanvas(this.mount.clientWidth, this.mount.clientHeight, renderer)
              : p.createCanvas(this.mount.clientWidth, this.mount.clientHeight);
            canvas.parent(this.mount);
            p.pixelDensity(1);
            this.state = pipeline.setup(p, this.params, canvas.elt);
            this.wrapper.dispatchEvent(new CustomEvent('sketch:ready'));
          };

          p.draw = () => {
            if (this.destroyed) return;
            pipeline.draw(p, this.params, this.state, this.frame++);
            this.wrapper.dispatchEvent(new CustomEvent('sketch:frame', { detail: this.frame }));
          };
        });

        const ro = new ResizeObserver(this.debounce(() => {
          if (this.p5Instance && !this.destroyed) {
            this.p5Instance.resizeCanvas(this.mount.clientWidth, this.mount.clientHeight);
          }
        }, 200));
        ro.observe(this.mount);

        this.wrapper.addEventListener('params:update', ((e: CustomEvent) => {
          this.params = { ...this.params, ...e.detail };
          if (this.pipeline?.onParamChange && this.p5Instance) {
            this.pipeline.onParamChange(this.p5Instance, this.params, this.state);
          }
        }) as EventListener);

        this.wrapper.addEventListener('sketch:pause', () => {
          if (this.p5Instance) this.p5Instance.noLoop();
        });

        this.wrapper.addEventListener('sketch:play', () => {
          if (this.p5Instance) this.p5Instance.loop();
        });

        this.wrapper.addEventListener('sketch:newSeed', () => {
          if (this.p5Instance && this.pipeline) {
            this.frame = 0;
            this.state = this.pipeline.setup(this.p5Instance, this.params, this.mount.querySelector('canvas')!);
          }
        });

        this.wrapper.addEventListener('sketch:destroy', () => {
          this.destroy();
        });

      } catch (err) {
        console.error('Sketch load error:', err);
        const errorEl = this.wrapper.querySelector('.sketch-error') as HTMLElement;
        if (errorEl) {
          errorEl.classList.remove('hidden');
          errorEl.querySelector('span')!.textContent = `Error: ${err}`;
        }
        this.wrapper.dispatchEvent(new CustomEvent('sketch:error', { detail: err }));
      }
    }

    getDefaults(): ParamValues {
      if (!this.pipeline) return {};
      const defaults: ParamValues = {};
      for (const [key, def] of Object.entries(this.pipeline.params)) {
        defaults[key] = def.default;
      }
      return defaults;
    }

    private destroy() {
      this.destroyed = true;
      if (this.pipeline?.destroy) {
        this.pipeline.destroy(this.state);
      }
      if (this.p5Instance) {
        this.p5Instance.remove();
        this.p5Instance = null;
      }
    }

    private debounce(fn: () => void, ms: number) {
      let timer: ReturnType<typeof setTimeout>;
      return () => {
        clearTimeout(timer);
        timer = setTimeout(fn, ms);
      };
    }
  }

  document.querySelectorAll('.sketch-canvas-wrapper').forEach(el => {
    new SketchRunner(el as HTMLElement);
  });
</script>
