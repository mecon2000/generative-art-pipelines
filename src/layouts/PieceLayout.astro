---
import BaseLayout from './BaseLayout.astro';
import SketchCanvas from '../components/SketchCanvas.astro';
import ParamPanel from '../components/ParamPanel.astro';
import type { Pipeline, ParamValues } from '../pipelines/_types';
import { getTheme } from '../data/themes';

interface Props {
  pipeline: Pipeline;
}

const { pipeline } = Astro.props;
const theme = getTheme(pipeline.theme);
const isAnimated = pipeline.animated !== false;

const urlParams = Astro.url.searchParams;
const initialValues: ParamValues = {};
for (const [key, def] of Object.entries(pipeline.params)) {
  const urlVal = urlParams.get(key);
  if (urlVal !== null) {
    if (def.type === 'range') initialValues[key] = parseFloat(urlVal);
    else if (def.type === 'boolean') initialValues[key] = urlVal === 'true';
    else initialValues[key] = urlVal;
  } else {
    initialValues[key] = def.default;
  }
}
---
<BaseLayout title={`${pipeline.name} — Generative Art Pipelines`} description={pipeline.description}>
  <div
    class="piece-page flex flex-col lg:flex-row h-[calc(100vh-4rem)]"
    style={theme ? `--color-accent: ${theme.accentColor}; --color-accent-dim: ${theme.accentDim};` : ''}
    data-pipeline-id={pipeline.id}
  >
    <div class="flex-1 relative">
      <SketchCanvas
        pipelineId={pipeline.id}
        theme={pipeline.theme}
        params={initialValues}
        interactive={true}
        class="w-full h-full"
      />

      <div class="absolute bottom-0 left-0 right-0 p-4 flex items-center justify-center gap-2 flex-wrap bg-gradient-to-t from-void/60 to-transparent">
        <button class="tool-btn btn text-xs" data-action="newSeed">New Seed</button>
        <button class="tool-btn btn text-xs" data-action="save">Save PNG</button>
        <button class="tool-btn btn text-xs" data-action="fullscreen">Fullscreen</button>
        <button class="tool-btn btn text-xs" data-action="share">Share</button>
      </div>
    </div>

    <div class="panel-wrap hidden lg:flex flex-shrink-0 relative" data-collapsed="false">
      <button
        id="panel-toggle"
        class="panel-toggle group h-full w-6 flex items-center justify-center border-l border-border bg-surface hover:bg-surface-2 transition-colors duration-300 ease-expo"
        aria-label="Toggle parameters"
        aria-expanded="true"
      >
        <svg class="panel-toggle-icon w-3 h-3 text-text-muted group-hover:text-accent transition-all duration-300 ease-expo" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8 2 L4 6 L8 10" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="param-panel-container w-80 overflow-hidden transition-all duration-300 ease-expo">
        <ParamPanel pipeline={pipeline} values={initialValues} showPause={isAnimated} />
      </div>
    </div>

    <button
      id="mobile-param-toggle"
      class="lg:hidden fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-accent text-void flex items-center justify-center shadow-lg"
      aria-label="Toggle parameters"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="21" x2="4" y2="14" /><line x1="4" y1="10" x2="4" y2="3" />
        <line x1="12" y1="21" x2="12" y2="12" /><line x1="12" y1="8" x2="12" y2="3" />
        <line x1="20" y1="21" x2="20" y2="16" /><line x1="20" y1="12" x2="20" y2="3" />
        <line x1="1" y1="14" x2="7" y2="14" /><line x1="9" y1="8" x2="15" y2="8" />
        <line x1="17" y1="16" x2="23" y2="16" />
      </svg>
    </button>

    <div id="mobile-param-panel" class="lg:hidden fixed inset-x-0 bottom-0 z-40 translate-y-full transition-transform duration-300 ease-expo max-h-[70vh] overflow-y-auto">
      <ParamPanel pipeline={pipeline} values={initialValues} showPause={isAnimated} />
    </div>
  </div>

  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 bg-surface-2 border border-border text-text px-4 py-2 rounded font-mono text-xs opacity-0 pointer-events-none transition-opacity duration-300">
    Link copied to clipboard
  </div>
</BaseLayout>

<script>
  const page = document.querySelector('.piece-page') as HTMLElement;
  const pipelineId = page?.dataset.pipelineId;
  const canvas = page?.querySelector('.sketch-canvas-wrapper') as HTMLElement;

  // ------- Sidebar toggle (desktop) -------
  const panelWrap = page?.querySelector('.panel-wrap') as HTMLElement;
  const panelContainer = panelWrap?.querySelector('.param-panel-container') as HTMLElement;
  const panelToggle = document.getElementById('panel-toggle');
  const panelToggleIcon = panelToggle?.querySelector('.panel-toggle-icon') as SVGElement | null;

  panelToggle?.addEventListener('click', () => {
    const collapsed = panelWrap.dataset.collapsed === 'true';
    const next = !collapsed;
    panelWrap.dataset.collapsed = String(next);
    panelToggle.setAttribute('aria-expanded', String(!next));

    if (panelContainer) {
      panelContainer.style.width = next ? '0px' : '20rem'; // 20rem = w-80
    }
    if (panelToggleIcon) {
      panelToggleIcon.style.transform = next ? 'scaleX(-1)' : 'scaleX(1)';
    }
  });

  // ------- Pause/Play (lives inside param panel) -------
  let paused = false;
  document.querySelectorAll('.pause-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      paused = !paused;
      canvas?.dispatchEvent(new CustomEvent(paused ? 'sketch:pause' : 'sketch:play'));
      document.querySelectorAll('.pause-btn').forEach(b => {
        const icon = b.querySelector('.pause-icon') as SVGElement | null;
        const playIcon = b.querySelector('.play-icon') as SVGElement | null;
        const lbl = b.querySelector('.pause-label');
        if (paused) {
          icon?.classList.add('hidden');
          playIcon?.classList.remove('hidden');
          if (lbl) lbl.textContent = 'Play';
        } else {
          icon?.classList.remove('hidden');
          playIcon?.classList.add('hidden');
          if (lbl) lbl.textContent = 'Pause';
        }
        b.setAttribute('aria-label', paused ? 'Play' : 'Pause');
      });
    });
  });

  // ------- Toolbar actions -------
  document.querySelectorAll('.tool-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = (btn as HTMLElement).dataset.action;

      if (action === 'save') {
        const c = canvas?.querySelector('canvas');
        if (c) {
          const link = document.createElement('a');
          link.download = `${pipelineId}.png`;
          link.href = c.toDataURL('image/png');
          link.click();
        }
      }

      if (action === 'fullscreen') {
        const c = canvas?.querySelector('canvas');
        if (c) {
          if (document.fullscreenElement) {
            document.exitFullscreen();
          } else {
            c.requestFullscreen();
          }
        }
      }

      if (action === 'newSeed') {
        canvas?.dispatchEvent(new CustomEvent('sketch:newSeed'));
      }

      if (action === 'share') {
        const params = new URLSearchParams();
        const panel = document.querySelector(`.param-panel[data-pipeline-id="${pipelineId}"]`);
        if (panel) {
          panel.querySelectorAll('.param-input').forEach(input => {
            const key = (input as HTMLElement).dataset.paramKey!;
            const type = (input as HTMLElement).dataset.paramType!;
            let val: string;
            if (type === 'boolean') {
              val = String((input as HTMLInputElement).checked);
            } else {
              val = (input as HTMLInputElement).value;
            }
            params.set(key, val);
          });
        }
        const url = `${window.location.origin}${window.location.pathname}?${params.toString()}`;
        navigator.clipboard.writeText(url).then(() => {
          const toast = document.getElementById('toast');
          if (toast) {
            toast.style.opacity = '1';
            setTimeout(() => { toast.style.opacity = '0'; }, 2000);
          }
        });
      }
    });
  });

  // ------- Mobile param panel toggle -------
  const mobileToggle = document.getElementById('mobile-param-toggle');
  const mobilePanel = document.getElementById('mobile-param-panel');
  let mobileOpen = false;

  mobileToggle?.addEventListener('click', () => {
    mobileOpen = !mobileOpen;
    if (mobilePanel) {
      mobilePanel.style.transform = mobileOpen ? 'translateY(0)' : 'translateY(100%)';
    }
  });
</script>
